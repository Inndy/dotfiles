#!/usr/bin/env bash
#
# claude-launcher — named-account wrapper for `claude` (Claude Code).
#
# ── CONTRACT ───────────────────────────────────────────────────────────────
#
# Claude Code reads ONE env var: $CLAUDE_CONFIG_DIR. Everything else
# below is invented by this wrapper and is invisible to claude itself.
#
# Wrapper-owned env vars
#   CC_ACCOUNT         The account *name*. In wrapper-managed mode the
#                      wrapper sets it from the resolved account and the
#                      name drives where CLAUDE_CONFIG_DIR points. In
#                      raw passthrough it becomes a display-only label
#                      (like a venv name) — read by other wrapper tools
#                      (statusline, hooks, nested `cc` calls). Never
#                      read by claude.
#   CLAUDE_CONFIG_DIR  Shared with claude. The wrapper sets it from the
#                      resolved account directory, or unsets it to mean
#                      "use native ~/.claude". When pre-set by the
#                      caller it's treated as a *location* ("store my
#                      claude config here") and the wrapper honors it.
#
# Reserved name
#   default            Virtual account meaning "native ~/.claude — do
#                      not switch". Valid for `cc -a default` and `cc
#                      use default`; rejected by `cc setup default`.
#
# Account resolution (highest precedence first; more-specific overrides
# less-specific, args beat env)
#   1. `-a <name>` flag                       (this-invocation explicit)
#   2. pre-set $CLAUDE_CONFIG_DIR             (caller's explicit env;
#                                              what claude actually reads)
#   3. inherited $CC_ACCOUNT                  (wrapper metadata)
#   4. ~/.claude-accounts/.default            (persistent default)
#   5. virtual `default` (native)             (fallback)
#
# When a higher signal is present, lower signals are overridden silently —
# they're hints, not constraints. Example: `CC_ACCOUNT=a CLAUDE_CONFIG_DIR=
# /path/b cc` uses /path/b ("override CC_ACCOUNT name"); `CC_ACCOUNT=a cc
# -a b` uses b (args beat env).
#
# Operating modes (consequence of resolution, not separate decisions)
#   Wrapper-managed   ACCOUNT resolves to a named account dir under
#                     $ACCOUNTS_DIR. Wrapper exports $CC_ACCOUNT, sets
#                     $CLAUDE_CONFIG_DIR to the account dir, sources
#                     both env files.
#   Virtual default   ACCOUNT resolves to native (`-a default`, or no
#                     signal at all). $CLAUDE_CONFIG_DIR unset,
#                     $CC_ACCOUNT="default", only global env sourced.
#   Raw passthrough   $CLAUDE_CONFIG_DIR was pre-set by the caller.
#                     Dir kept as-is, inherited $CC_ACCOUNT left
#                     untouched as a display-only label (like a venv
#                     name). Only global env sourced — per-account env
#                     is the caller's responsibility now. `cc usage`
#                     still works against the chosen dir.
#
# Behavior table (PREFIX = ~/.claude-accounts; `-` = unset; `*` = any value)
#
#   inputs                                output env passed to claude
#   `cc -a`   CC_ACCOUNT   CCD              CC_ACCOUNT     CCD               behavior
#   -------   ----------   ------           ----------     ---------------   -----------------------------
#   acc_a     *            *                acc_a          PREFIX/acc_a      -a wins: activate acc_a
#   default   *            *                default        -                 -a wins: deactivate to native
#   -         acc_b        -                acc_b          PREFIX/acc_b      CC_ACCOUNT drives activation
#   -         default      -                default        -                 virtual default (native)
#   -         acc_b        /tmp/b           acc_b          /tmp/b            raw passthrough; acc_b = label
#   -         default      /tmp/b           default        /tmp/b            raw passthrough; default label
#   -         -            /tmp/b           -              /tmp/b            raw passthrough; no label
#   -         -            -                <see below>    <see below>       fall through to .default file
#
#   Last row depends on ~/.claude-accounts/.default contents:
#     real account name  →  CC_ACCOUNT=<name>,   CCD=PREFIX/<name>
#     "default" / absent →  CC_ACCOUNT="default", CCD unset (native)
#
# Env config (sourced before launch; shell syntax)
#   ~/.claude-accounts/env           global; sourced in all modes
#   ~/.claude-accounts/<name>/env    per-account; overrides global;
#                                    sourced only in wrapper-managed
#                                    mode
#
#   Env files can only INTRODUCE new vars — they cannot override vars
#   the caller already set (inline `FOO=bar cc`, inherited from a
#   parent, or set by an earlier env file). Precedence high to low:
#   caller env > per-account env > global env.
#
# ───────────────────────────────────────────────────────────────────────────

set -euo pipefail

CLAUDE_BASE="${HOME}/.claude"
ACCOUNTS_DIR="${HOME}/.claude-accounts"
DEFAULT_FILE="${ACCOUNTS_DIR}/.default"

die() { echo "${0##*/}: $*" >&2; exit 1; }

# All JSON reads below use jq. On a box without jq, shim the SUBSET this script
# uses via python3 (python3 is far likelier than jq to be present on a machine
# already running claude). The shim runs ONLY where jq is absent, so it is never
# exercised on a dev box that has jq — a divergence would surface only on
# jq-less hosts. MAINTAINER: the shim understands just `-r` and a
# `.dotted.path` filter with an optional `// "str"` or `// empty` fallback. Any
# richer jq filter (arrays, select, pipes, @-filters) makes it die with
# "jq-shim: unsupported". Extend the shim or require real jq; never let it
# silently diverge.
if ! command -v jq >/dev/null 2>&1; then
  jq() {
    local raw=0
    while [[ "${1:-}" == -* ]]; do
      case "$1" in
        -r) raw=1 ;;
        *)  die "jq-shim: unsupported flag: $1" ;;
      esac
      shift
    done
    python3 -c '
import json, sys
filt, raw = sys.argv[1], sys.argv[2] == "1"
src = sys.argv[3:]
path, sep, dflt = filt.partition("//")
path = path.strip()
if not path.startswith(".") or any(c in path for c in "[]|()?*@ \t"):
    sys.stderr.write("jq-shim: unsupported filter: %s\n" % filt)
    sys.exit(2)
default = None
if sep:
    d = dflt.strip()
    default = "" if d == "empty" else d.strip("\x27\"")
try:
    doc = json.load(open(src[0])) if src else json.load(sys.stdin)
except Exception:
    sys.exit(4)
node = doc
for key in [k for k in path.lstrip(".").split(".") if k]:
    node = node.get(key) if isinstance(node, dict) else None
    if node is None:
        break
if node is None:
    node = default if default is not None else ""
print(node if raw else json.dumps(node))
' "$1" "$raw" "${@:2}"
  }
fi

_spawn_headless() {
  # Spawns "$@" in a detached background session and waits for it to exit.
  # First arg is a session name used by the multiplexer.
  # TODO: add GNU screen fallback for environments without tmux
  local session="$1"; shift
  if command -v tmux &>/dev/null; then
    tmux kill-session -t "=${session}" 2>/dev/null || true
    local eargs=()
    local v
    for v in CC_HI_SESSION CLAUDE_CONFIG_DIR CC_ACCOUNT; do
      [[ -n "${!v:-}" ]] && eargs+=(-e "${v}=${!v}")
    done
    tmux new-session -d -s "$session" "${eargs[@]}" -- "$@"
    while tmux has-session -t "=${session}" 2>/dev/null; do sleep 0.2; done
  else
    "$@"
  fi
}

_link_account_dir() {
  local dir="$1"
  mkdir -p "$dir"
  shopt -s dotglob nullglob
  for item in "${CLAUDE_BASE}"/*; do
    local base="${item##*/}"
    [[ "$base" == ".credentials.json" ]] && continue
    [[ -e "${dir}/${base}" || -L "${dir}/${base}" ]] && continue
    ln -s "$item" "${dir}/${base}"
  done
  shopt -u dotglob nullglob
}

_load_env() {
  [[ -f "$1" ]] || return 0
  # $2 (optional) is a snapshot from `export -p`. After sourcing the file
  # we re-apply the snapshot so the file can ADD new vars but cannot
  # override caller-set vars (or launcher-managed vars in raw passthrough).
  set -a; source "$1"; set +a
  [[ -n "${2:-}" ]] && eval "$2"
}

_resolve_account() {
  local explicit_a="${ACCOUNT:+1}"
  # Snapshot caller env for env-file protection (see CONTRACT). Exclude the
  # launcher-managed vars — those are owned by resolution logic, not env
  # files. Raw passthrough re-adds CLAUDE_CONFIG_DIR below.
  local snapshot
  snapshot=$(export -p | grep -vE '^declare -x (CC_ACCOUNT|CLAUDE_CONFIG_DIR)=' || true)

  # Resolve ACCOUNT name. Precedence (see CONTRACT):
  #   -a > pre-set CLAUDE_CONFIG_DIR > inherited CC_ACCOUNT > .default > "default"
  if [[ -z "$ACCOUNT" ]]; then
    if [[ -n "${CLAUDE_CONFIG_DIR:-}" ]]; then
      # Caller set CLAUDE_CONFIG_DIR — that's where their config lives.
      # Raw passthrough: don't derive ACCOUNT, don't touch CC_ACCOUNT
      # (it's a display label, like a venv name). Load only the global env.
      snapshot+=$'\n'$(declare -p CLAUDE_CONFIG_DIR)
      _load_env "${ACCOUNTS_DIR}/env" "$snapshot"
      return
    elif [[ -n "${CC_ACCOUNT:-}" ]]; then
      ACCOUNT="$CC_ACCOUNT"
    elif [[ -f "$DEFAULT_FILE" ]]; then
      ACCOUNT=$(< "$DEFAULT_FILE")
    fi
  fi
  if [[ "$ACCOUNT" == "default" ]]; then
    ACCOUNT=""
    # Explicit `-a default` deactivates even an inherited CLAUDE_CONFIG_DIR.
    [[ "$explicit_a" == "1" ]] && unset CLAUDE_CONFIG_DIR
  fi
  if [[ -n "$ACCOUNT" ]]; then
    local dir="${ACCOUNTS_DIR}/${ACCOUNT}"
    [[ -d "$dir" ]] || die "Unknown account: ${ACCOUNT} (run: cc setup ${ACCOUNT})"
    export CLAUDE_CONFIG_DIR="$dir"
  fi
  _load_env "${ACCOUNTS_DIR}/env" "$snapshot"
  if [[ -n "$ACCOUNT" ]]; then
    _load_env "${ACCOUNTS_DIR}/${ACCOUNT}/env" "$snapshot"
  fi
}

_get_oauth_token() {
  local config_dir="$1"
  local token=""

  if [[ "$(uname)" == "Darwin" ]]; then
    # On macOS, credentials live in Keychain as JSON.
    # Service name includes a sha256 hash suffix for non-default config dirs
    # (mirrors the logic in src/utils/secureStorage/macOsKeychainHelpers.ts).
    local service="Claude Code-credentials"
    if [[ -n "${CLAUDE_CONFIG_DIR:-}" ]]; then
      local hash
      hash=$(printf '%s' "$config_dir" | shasum -a 256 | cut -c1-8)
      service="Claude Code-credentials-${hash}"
    fi

    token=$(security find-generic-password -a "$USER" -w -s "$service" 2>/dev/null |
      jq -r '.claudeAiOauth.accessToken // empty' 2>/dev/null || true)
  fi

  # Fallback: plain-text .credentials.json (Linux default, or macOS keychain miss)
  if [[ -z "$token" ]]; then
    local creds="${config_dir}/.credentials.json"
    [[ -f "$creds" ]] && token=$(jq -r '.claudeAiOauth.accessToken // empty' "$creds" 2>/dev/null)
  fi

  echo "$token"
}

_show_usage() {
  local config_dir="$1" account_label="$2" raw_json="$3"
  local token
  token=$(_get_oauth_token "$config_dir")
  [[ -z "$token" ]] && die "No OAuth token found for account: ${account_label}"
  local result http
  result=$(curl -s --max-time 10 -w $'\n%{http_code}' \
    -H "Authorization: Bearer $token" \
    -H "Content-Type: application/json" \
    https://api.anthropic.com/api/oauth/usage) || die "API request failed (network error)"
  http="${result##*$'\n'}"; result="${result%$'\n'*}"
  if [[ "$http" != "200" ]]; then
    case "$http" in
      401) die "API returned 401 for '${account_label}' — token expired; run: cc setup ${account_label}" ;;
      429) die "API returned 429 for '${account_label}' — rate limited, try again later" ;;
      *)   die "API returned HTTP ${http} for '${account_label}': ${result}" ;;
    esac
  fi

  if [ -n "$raw_json" ]
  then
    printf '%s\n' "$result"
    return
  fi
  local five_h five_reset seven_d seven_reset
  five_h=$(echo "$result"      | jq -r '.five_hour.utilization // empty')
  [[ -z "$five_h" ]] && die "Unexpected API response: $result"
  five_reset=$(echo "$result"  | jq -r '.five_hour.resets_at // "?"')
  seven_d=$(echo "$result"     | jq -r '.seven_day.utilization // "?"')
  seven_reset=$(echo "$result" | jq -r '.seven_day.resets_at // "?"')
  echo "Account  : ${account_label}"
  printf "5h limit : %s%% used  (resets %s)\n" "$five_h" "$five_reset"
  printf "7d limit : %s%% used  (resets %s)\n" "$seven_d" "$seven_reset"
}

cmd_help() {
  cat <<EOF
Usage: ${0##*/} [GLOBAL OPTIONS] [COMMAND] [ARGS]

Commands:
  setup <name>        create account dir + launch to authenticate
  use <name>          set default account
  list                list accounts with credential status
  usage [--json]      show quota usage for current/specified account
  hi                  trigger 5h window (Haiku ping; auto-closes via stop hook)
  -h, --help, help    show this help

Global options (before subcommand):
  -a, --account <name>  use specific account. Resolution order when omitted:
                        inherited \$CC_ACCOUNT > ~/.claude-accounts/.default > 'default'

Reserved account name:
  default               virtual — do NOT switch; use native ~/.claude

Launch options (when no subcommand):
  --yolo                --dangerously-skip-permissions
  --                    end of launcher options; remaining args go to claude

Env config (optional, sourced before launch):
  ~/.claude-accounts/env          global env vars for all accounts
  ~/.claude-accounts/<name>/env   per-account env vars (takes precedence)

Examples:
  cc setup work           # create 'work' account, authenticate
  cc use work             # set 'work' as default
  cc use default          # pin native ~/.claude as default
  cc                      # launch with resolved account
  cc -a personal          # launch with 'personal' account
  cc -a default           # launch with native ~/.claude (no switching)
  cc --yolo               # launch without permission prompts
  cc -- -h                # show claude's own help
  cc -a work -- -h        # show claude's help under 'work' account
  DEBUG=1 cc              # inline env vars (merged with config files)
  cc usage                # quota usage for resolved account
  cc usage --json         # raw JSON from the quota API
  cc -a work usage        # quota usage for 'work' account
EOF
}

cmd_setup() {
  local name="${1:?Usage: cc setup <name>}"
  [[ "$name" == "default" ]] && die "'default' is reserved (means native ~/.claude); pick a different name"
  local dir="${ACCOUNTS_DIR}/${name}"
  _link_account_dir "$dir"
  echo "Launching claude for '${name}' — log in to save credentials..."
  export CLAUDE_CONFIG_DIR="$dir"
  exec claude
}

cmd_use() {
  local name="${1:?Usage: cc use <name>}"
  if [[ "$name" != "default" ]]; then
    [[ -d "${ACCOUNTS_DIR}/${name}" ]] || die "Unknown account: ${name}"
  fi
  echo "$name" > "$DEFAULT_FILE"
  echo "Default: ${name}"
}

cmd_list() {
  local default=""; [[ -f "$DEFAULT_FILE" ]] && default=$(< "$DEFAULT_FILE")
  [[ -z "$default" ]] && default="default"
  local marker="  "; [[ "$default" == "default" ]] && marker="* "
  echo "${marker}default  [native ~/.claude]"
  shopt -s nullglob
  for d in "${ACCOUNTS_DIR}"/*/; do
    local name="${d%/}"; name="${name##*/}"
    local marker="  "; [[ "$name" == "$default" ]] && marker="* "
    local creds="${d}.credentials.json"
    local tier
    if [[ -f "$creds" ]]; then
      tier=$(jq -r '.claudeAiOauth.rateLimitTier // "?"' "$creds" 2>/dev/null || echo "?")
    else
      tier="no credentials"
    fi
    echo "${marker}${name}  [${tier}]"
  done
}

cmd_hi() {
  _resolve_account
  if [[ -n "$ACCOUNT" ]]; then
    export CC_ACCOUNT="$ACCOUNT"
  elif [[ -z "${CLAUDE_CONFIG_DIR:-}" ]]; then
    export CC_ACCOUNT="default"
  fi
  export CC_HI_SESSION=1
  # bash -c forks a child; $$ inside is that child's PID. exec claude then
  # replaces the child in-place, so CC_HI_SESSION_PID == claude's PID.
  mkdir -p /tmp/.cc-hi-workdir
  _spawn_headless "cc-hi" bash -c 'cd /tmp/.cc-hi-workdir && export CC_HI_SESSION_PID=$$; exec claude --model haiku "Reply with exactly one word: Hi"' || true
  # Cleanup after claude fully exits — the stop hook only sends SIGINT; if we
  # deleted here in the hook, claude would recreate the dir during its own
  # shutdown flush. Deleting here guarantees we run after the process is gone.
  local config_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
  local project_dir="${config_dir}/projects/-tmp--cc-hi-workdir"
  local f session_id
  for f in "${project_dir}"/*.jsonl; do
    [[ -f "$f" ]] || continue
    session_id="${f%.jsonl}"; session_id="${session_id##*/}"
    [[ -n "$session_id" ]] && rm -rf "${config_dir}/file-history/${session_id}"
  done
  rm -rf "$project_dir"
  cmd_usage
}

cmd_hi_cleanup_hook() {
  [[ "${CC_HI_SESSION:-}" == "1" ]] || return 0
  cat > /dev/null
  [[ -n "${CC_HI_SESSION_PID:-}" ]] && kill -INT "$CC_HI_SESSION_PID" 2>/dev/null || true
}

cmd_usage() {
  local raw_json=""
  case "${1-}" in
    "")     ;;
    --json) raw_json=1 ;;
    *)      die "Usage: cc usage [--json]" ;;
  esac
  _resolve_account
  # Display label: resolved ACCOUNT if set, else inherited CC_ACCOUNT (raw
  # passthrough display label), else "default".
  _show_usage "${CLAUDE_CONFIG_DIR:-$HOME/.claude}" "${ACCOUNT:-${CC_ACCOUNT:-default}}" "$raw_json"
}

cmd_launch() {
  local claude_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yolo) claude_args+=("--dangerously-skip-permissions"); shift ;;
      --)     shift; claude_args+=("$@"); break ;;
      *)      claude_args+=("$1"); shift ;;
    esac
  done
  _resolve_account
  # Set CC_ACCOUNT to the resolved account name. Raw passthrough
  # (CLAUDE_CONFIG_DIR set, ACCOUNT empty) leaves any inherited CC_ACCOUNT
  # alone — in that mode it's a display-only label (like a venv name).
  if [[ -n "$ACCOUNT" ]]; then
    export CC_ACCOUNT="$ACCOUNT"
  elif [[ -z "${CLAUDE_CONFIG_DIR:-}" ]]; then
    export CC_ACCOUNT="default"
  fi
  exec claude "${claude_args[@]}"
}

# ---- main: phase 1 (global opts) → phase 2 (dispatch) ----

ACCOUNT=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -a|--account) ACCOUNT="$2"; shift 2 ;;
    *) break ;;
  esac
done

case "${1-}" in
  -h|--help|help) cmd_help ;;
  setup) shift; cmd_setup "$@" ;;
  use)   shift; cmd_use   "$@" ;;
  list)  shift; cmd_list  "$@" ;;
  usage) shift; cmd_usage "$@" ;;
  hi)              cmd_hi ;;
  hi-cleanup-hook) cmd_hi_cleanup_hook ;;
  *)               cmd_launch "$@" ;;
esac

# vim: set et sw=2 :
